{
  "version": 1,
  "verified_at": "2026-05-28",
  "notes": "Manifest sumber data yang sudah dicek dari Hugging Face/API publik. Builder tetap memvalidasi license tag sebelum mengambil data.",
  "sources": [
    {
      "id": "nixia_seed",
      "enabled": false,
      "type": "local_text",
      "path": "data/sample_corpus.txt",
      "adapter": "nixia_text",
      "license": "project-local",
      "license_class": "permissive",
      "use": "chat",
      "quality": "manual seed: casual Indonesian + Jawa/Sunda + roleplay ringan"
    },
    {
      "id": "lorthgyu_indonesian_chat",
      "enabled": false,
      "type": "hf_raw_jsonl",
      "repo": "LorthGyu/indonesian-chat",
      "file": "data/train.jsonl",
      "adapter": "hf_conversations",
      "license": "mit",
      "license_class": "permissive",
      "use": "chat",
      "quality": "200 multi-turn Indonesian chats; casual/formal/mixed; direct conversational schema"
    },
    {
      "id": "lorthgyu_indonesian_qa",
      "enabled": false,
      "type": "hf_raw_jsonl",
      "repo": "LorthGyu/indonesian-qa",
      "file": "data/train.jsonl",
      "adapter": "qa_pair",
      "question_fields": [
        "question"
      ],
      "answer_fields": [
        "answer"
      ],
      "license": "mit",
      "license_class": "permissive",
      "use": "general_qa_small",
      "quality": "200 Indonesian QA pairs; useful as small knowledge/style supplement, not primary casual chat"
    },
    {
      "id": "w11wo_twitter_indonesia_sarcastic",
      "enabled": false,
      "type": "hf_raw_csv",
      "repo": "w11wo/twitter_indonesia_sarcastic",
      "file": "data/train.csv",
      "adapter": "hf_social_post",
      "text_fields": [
        "tweet"
      ],
      "license": "apache-2.0",
      "license_class": "permissive",
      "use": "social_style_seed",
      "quality": "Apache-2.0 Indonesian tweets with masked usernames/links; disabled by default because social media data needs stricter filtering and assistant replies are templated",
      "exclude_contains": [
        "dpr",
        "dprd",
        "pilpres",
        "pemilu",
        "partai",
        "jokowi",
        "prabowo",
        "anies",
        "ganjar"
      ]
    },
    {
      "id": "suryaadhi_ppmb_qa_id",
      "enabled": false,
      "type": "hf_raw_jsonl",
      "repo": "suryaadhi/ppmb-qa-dataset",
      "file": "ppmb-qa-id.jsonl",
      "adapter": "qa_pair",
      "question_fields": [
        "query"
      ],
      "answer_fields": [
        "answer"
      ],
      "license": "mit",
      "license_class": "permissive",
      "use": "helpdesk_qa",
      "quality": "353 Indonesian helpdesk/social-style admission QA rows; answers are shortened by builder and source is domain-specific"
    },
    {
      "id": "gabrielb_python_qa",
      "enabled": true,
      "type": "hf_raw_csv",
      "repo": "gabrielb/QA-Python-Programming-Indonesia",
      "file": "original_dataset.csv",
      "adapter": "legacy_conversations",
      "license": "apache-2.0",
      "license_class": "permissive",
      "use": "technical_qa_supplement",
      "quality": "5.6K Indonesian Python QA rows; optional small supplement only because it can shift Nixia toward coding assistant behavior"
    },
    {
      "id": "indonlp_cendol_chat_v2",
      "enabled": false,
      "type": "hf_rows",
      "repo": "indonlp/cendol_collection_v2",
      "config": "default",
      "split": "train",
      "adapter": "hf_input_output",
      "license": "apache-2.0",
      "license_class": "permissive",
      "use": "instruction_chat",
      "quality": "12.8M Indonesian instruction/chat rows; bagus untuk pretraining/instruction, tetapi tidak default untuk corpus chat kasual karena banyak row ensiklopedis/task non-chat",
      "start_offsets": [
        0,
        6000000,
        9000000,
        12000000
      ],
      "exclude_subset_contains": [
        "puisi",
        "topic",
        "rhetoric",
        "translation",
        "mt",
        "ner",
        "pos",
        "summarization"
      ]
    },
    {
      "id": "seacrowd_seadialogues",
      "enabled": false,
      "type": "hf_rows",
      "repo": "SEACrowd/SEADialogues",
      "config": "default",
      "split": "train",
      "adapter": "sea_dialogues",
      "license": "cc-by-sa-4.0",
      "license_class": "sharealike",
      "use": "chat_cultural",
      "quality": "8K culturally grounded multi-turn SEA conversations; include with --allow-sharealike",
      "lang_allow": [
        "ind",
        "jav",
        "sun",
        "min"
      ],
      "dialogue_fields": [
        "generated_convo_gemini15flash",
        "generated_convo_gpt4omini"
      ]
    },
    {
      "id": "indonlp_nusax_mt",
      "enabled": false,
      "type": "hf_rows",
      "repo": "indonlp/NusaX-MT",
      "config": "default",
      "split": "train",
      "adapter": "nusa_phrase_pair",
      "license": "cc-by-sa-4.0",
      "license_class": "sharealike",
      "use": "dialect_lexical_pretrain",
      "quality": "expert translated Indonesian + local language parallel corpus; useful for tokenizer/pretraining, not primary chat"
    },
    {
      "id": "noura_roleplay_chat",
      "enabled": false,
      "type": "hf_rows",
      "repo": "Nourivex/Noura-Roleplay-Chat",
      "config": "default",
      "split": "train",
      "adapter": "unknown_json",
      "license": "cc-by-nc-sa-4.0",
      "license_class": "noncommercial",
      "use": "roleplay",
      "quality": "roleplay Indonesian dataset; skip by default because non-commercial/share-alike"
    },
    {
      "id": "sahil2801_codealpaca",
      "enabled": true,
      "type": "hf_rows",
      "repo": "sahil2801/CodeAlpaca-20k",
      "config": "default",
      "split": "train",
      "adapter": "hf_input_output",
      "license": "apache-2.0",
      "license_class": "permissive",
      "use": "instruction_chat",
      "quality": "20K rows of code generation tasks from Alpaca"
    }
  ]
}